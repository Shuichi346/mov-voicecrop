# whisper.cpp パス設定
WHISPER_CLI_PATH=./whisper.cpp/build/bin/whisper-cli
WHISPER_MODEL_PATH=./whisper.cpp/models/ggml-large-v3-turbo.bin
WHISPER_VAD_MODEL_PATH=./whisper.cpp/models/ggml-silero-v6.2.0.bin

# 音声認識設定
LANGUAGE=ja
WHISPER_THREADS=8
MIN_CONFIDENCE=0.35

# 無音検出設定
SILENCE_THRESH_DB=-35
MIN_SILENCE_DURATION=0.25
PADDING=0.15

# MP4出力設定
# 字幕モード: soft（ソフトサブ） / off（字幕なし）
SUBTITLE_MODE=soft
# 映像エンコーダー: auto（HW利用可能なら自動選択） / libx264 / h264_videotoolbox
VIDEO_ENCODER=auto

# FCPXML 出力ターゲット
# resolve: DaVinci Resolve 20 向け
# fcp: Final Cut Pro 12 向け
# both: 両方出力
FCPXML_TARGET=resolve

# 出力ディレクトリ（未指定なら入力動画と同じディレクトリに出力）
# OUTPUT_DIR=./output

# Gradio設定
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860